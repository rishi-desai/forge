# Copy to .env and fill in. All data/broker keys are free tiers.

# Broker — Alpaca PAPER account (https://alpaca.markets). Request options level 3.
ALPACA_API_KEY=
ALPACA_SECRET_KEY=

# Market data (free)
FINNHUB_API_KEY=          # https://finnhub.io  (60 req/min, 50-symbol WS)
FRED_API_KEY=             # https://fred.stlouisfed.org/docs/api/api_key.html

# Optional
# ANTHROPIC_API_KEY=      # only if rationale_llm_enabled=true in config.json

# API auth (recommended whenever the backend is exposed via a public tunnel).
# When set, every API route + the WebSocket require this token. Leave blank for
# purely-local use. For a stronger gate, also put Cloudflare Access in front.
# API_TOKEN=

# Runtime
RUN_BOT=1                 # 0 = dashboard/API only, no trading loop
# DB_PATH=/custom/path/trading.db

# Deploy: comma-separated CORS origins for the hosted frontend.
# FRONTEND_ORIGIN=https://forge.example.com

# ---- frontend/.env (Vite) ----
# VITE_API_URL=https://api.example.com
# VITE_API_TOKEN=          # must equal API_TOKEN above when auth is enabled
